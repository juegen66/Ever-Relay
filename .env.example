# Mastra / Copilot model providers (server/mastra/model)
# Copy to .env and set values. Do not commit .env.

# Primary LLM — used by desktop copilot (default base URL: Laozhang)
API_KEY=
BASE_URL=https://api.laozhang.ai/v1

# Tu-zi (兔子)
TUZI_API_KEY=
TUZI_BASE_URL=https://api.tu-zi.com/v1

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
