# Copy to .env and set values. Do not commit .env.

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# DATABASE_TEST_URL=postgresql://...  # optional, for integration tests (pnpm test:integration)

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-value
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS General
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1

# AWS S3
AWS_S3_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT=  # optional, for MinIO / Cloudflare R2 etc.

# AWS SES
AWS_SES_ACCESS_KEY_ID=      # optional, falls back to AWS_ACCESS_KEY_ID
AWS_SES_SECRET_ACCESS_KEY=  # optional, falls back to AWS_SECRET_ACCESS_KEY
AWS_SES_REGION=ap-southeast-1
AWS_SES_DEFAULT_FROM=noreply@example.com

# Mastra / LLM (e.g. Laozhang)
API_KEY=
BASE_URL=https://api.example.com/v1

# Inngest / E2B
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV_URL=http://localhost:8288
E2B_API_KEY=

AFS_EMBEDDING_API_KEY=  
AFS_EMBEDDING_BASE_URL=  
AFS_EMBEDDING_MODEL=text-embedding-3-small
AFS_EMBEDDING_MODEL_VERSION=text-embedding-3-small
AFS_EMBEDDING_DIMENSIONS=1536